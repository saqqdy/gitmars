{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"target": "ESNext",
		"baseUrl": ".",
		"rootDir": "src",
		"module": "ESNext",
		"paths": {
			"#lib/*": ["./src/*"],
			"#conf/*": ["./src/conf/*"]
		},
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "temp",
		"sourceMap": true
	},
	"exclude": ["test", "node_modules", "dist", "temp"]
}
