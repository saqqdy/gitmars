{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"target": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "dist",
		"removeComments": true,
		"sourceMap": false,
		"skipLibCheck": true
	},
	"include": ["**/*.ts", "**/*.mts", "typings", ".vitepress/**/*"],
	"exclude": ["__tests__", "../../temp", "dist", "node_modules"]
}
